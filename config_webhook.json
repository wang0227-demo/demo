[
    {
        "enabled": false,
        "name": "飞书机器人 (设备状态通知)",
        "url": "https://open.feishu.cn/open-apis/bot/v2/hook/59bbd34e-69d6-46d7-a9fa-755f117fd0de",
        "triggers": [
            "connected",
            "disconnected"
        ],
        "body": "{\"msg_type\": \"text\", \"content\": {\"text\": \"🔔 设备状态通知！\\nNAME：{name}\\nMAC：{mac}\\n当前状态：{event}\\n来至-HeartRateMonitor\"}}",
        "headers": "{\"Content-Type\": \"application/json\"}"
    },
    {
        "enabled": false,
        "name": "飞书机器人 (设备电量提醒)",
        "url": "https://open.feishu.cn/open-apis/bot/v2/hook/59bbd34e-69d6-46d7-a9fa-755f117fd0de",
        "triggers": [
            "low_battery"
        ],
        "body": "{\"msg_type\": \"text\", \"content\": {\"text\": \"🪫 设备电量过低提醒！\\nNAME：{name}\\nMAC：{mac}\\n当前状态：{event}\\n剩余电量：{battery} %\\n请及时充电，以免影响电池健康\\n来至-HeartRateMonitor\"}}",
        "headers": "{\"Content-Type\": \"application/json\"}"
    },
    {
        "enabled": false,
        "name": "飞书机器人 (心率异常警告)",
        "url": "https://open.feishu.cn/open-apis/bot/v2/hook/59bbd34e-69d6-46d7-a9fa-755f117fd0de",
        "triggers": [
            "heart_rate_updated"
        ],
        "body": "{\"msg_type\": \"text\", \"content\": {\"text\": \"🚨 心率异常警告！\\nNAME：{name}\\nMAC：{mac}\\n当前状态：{event}\\n心率数值：{bpm} BPM\\n警告！检测到心率异常，请注意休息\\n来至-HeartRateMonitor\"}}",
        "headers": "{\"Content-Type\": \"application/json\"}"
    },
    {
        "enabled": false,
        "name": "飞书机器人 (受惊红温警告)",
        "url": "https://open.feishu.cn/open-apis/bot/v2/hook/59bbd34e-69d6-46d7-a9fa-755f117fd0de",
        "triggers": [
            "heart_surprise"
        ],
        "body": "{\"msg_type\": \"text\", \"content\": {\"text\": \"🚨 受惊红温警告！\\nNAME：{name}\\nMAC：{mac}\\n当前状态：{event}\\n心率数值：{bpm} BPM\\n警告！当前处于受惊红温状态，请注意调整呼吸\\n来至-HeartRateMonitor\"}}",
        "headers": "{\"Content-Type\": \"application/json\"}"
    },
    {
        "enabled": false,
        "name": "飞书机器人 (程序启动通知)",
        "url": "https://open.feishu.cn/open-apis/bot/v2/hook/59bbd34e-69d6-46d7-a9fa-755f117fd0de",
        "triggers": [
            "app_start"
        ],
        "body": "{\"msg_type\":\"interactive\",\"card\":{\"header\":{\"title\":{\"tag\":\"plain_text\",\"content\":\"{event}-[{sponsor_tag}]\"},\"template\":\"blue\"},\"elements\":[{\"tag\":\"div\",\"text\":{\"tag\":\"lark_md\",\"content\":\"时间: {time}\\n地点: {location} ({ip})\\n设备: {name} ({mac})\\n系统: {os} \\n{promo}\"}},{\"tag\": \"hr\"},{\"tag\":\"note\",\"elements\":[{\"tag\":\"plain_text\",\"content\":\"HeartRateMonitor-{version}\\n机器码: {machine_id}\"}]}]}}",
        "headers": "{\"Content-Type\": \"application/json\"}"
    },
    {
        "enabled": false,
        "name": "自定义 API (数据存档)",
        "url": "http://127.0.0.1",
        "triggers": [
            "heart_rate_updated"
        ],
        "body": "{\"value1\": \"{bpm}\", \"value2\": \"{event}\\n来至-HeartRateMonitor\"}",
        "headers": "{\"Authorization\": \"Bearer YOUR_TOKEN\"}"
    }
]
